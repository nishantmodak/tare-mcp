{
  "name": "tare-mcp",
  "version": "0.3.0",
  "description": "Local-first CLI for analyzing MCP context weight and tool ambiguity.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "bin": {
    "tare-mcp": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nishantmodak/tare-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nishantmodak/tare-mcp/issues"
  },
  "homepage": "https://github.com/nishantmodak/tare-mcp#readme",
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "tokens",
    "context"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.4.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
